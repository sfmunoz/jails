FROM debian:trixie-20260223-slim

LABEL maintainer="46285520+sfmunoz@users.noreply.github.com"

WORKDIR /workspace

RUN apt-get update && \
  apt-get install -y --no-install-recommends \
    git gh jq curl ca-certificates procps sudo less iputils-ping && \
  apt-get clean && \
  rm -rf /var/lib/apt/lists/*

RUN for i in `seq 1000 1004` ; do \
  groupadd -g $i g$i ; \
  useradd -u $i -g $i -d /workspace -s /bin/bash u$i ; \
  done
